# GSTBK engineering environment template.
# Copy to .env for local use; never commit real secrets, certificates, or accounts.

# Repository root. Shells that support `pwd` can override this at runtime.
GSTBK_REPO_ROOT=.

# Rust (系统级编程语言) runtime shape.
GSTBK_PROXY_COUNT=1
GSTBK_NODE_COUNT=4
GSTBK_USER_COUNT=6
GSTBK_PROXY_ADDR=127.0.0.1:50000
GSTBK_PROXY_LISTEN_ADDR=0.0.0.0:50000
GSTBK_NODE_PORT_START=50001
GSTBK_NODE_PORT_END=50004
GSTBK_USER_PORT_START=60001
GSTBK_USER_PORT_END=60006

# CL (Castagnos-Laguillaumie，同态加密方案) native library path.
GSTBK_CL_ENCRYPT_DIR=./crates/cl_encrypt
LD_LIBRARY_PATH=./crates/cl_encrypt
GSTBK_RUNTIME_DIR=./runtime-state
GSTBK_CL_KEYPAIR_PATH=./runtime-state/cl_keypair.json
# Optional input copied by scripts/run-local/run-user.sh before signing.
# Generate it with: bash scripts/run-local/run-id-info.sh enc
# GSTBK_PERSONAL_INFO_PAYLOAD_PATH=./runtime-state/block_personal_info.json

# FISCO BCOS (金融区块链合作联盟开源区块链底层平台) local tool paths.
# Point these to the VM (Virtual Machine，虚拟机) or server installation.
FISCO_CONSOLE_DIR=/opt/fisco/console
FISCO_BCOS_CONSOLE_DIR=/opt/fisco/console
FISCO_BCOS_SDK_DIR=./chain-apps/fisco-bcos-java-sdk
FISCO_BCOS_NODE_DIR=/opt/fisco/nodes/127.0.0.1/node0

# Common FISCO BCOS node ports; adjust to the actual chain version and node config.
FISCO_RPC_PORT=8545
FISCO_CHANNEL_PORT=20200
FISCO_P2P_PORT=30300
FISCO_GROUP=group0
FISCO_CONFIG=./chain-apps/fisco-bcos-java-sdk/conf/config.toml

# Contract addresses are deployment outputs. Keep placeholders in the repository.
# The Rust bridge treats empty values and the all-zero placeholder as missing.
GSTBK_PERSONAL_INFO_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
GSTBK_SIGNATURE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Rust-to-chain bridge directories.
# Each directory must contain the wrapper expected by Rust:
# - GSTBK_PERSONAL_INFO_APP_DIR/info_run.sh
# - GSTBK_SIGNATURE_APP_DIR/signature_run.sh
# The bridge also accepts dist/info_run.sh or dist/signature_run.sh under these dirs.
GSTBK_PERSONAL_INFO_APP_DIR=./chain-apps/fisco-bcos-java-sdk
GSTBK_SIGNATURE_APP_DIR=./chain-apps/fisco-bcos-java-sdk

# Optional Java SDK (Software Development Kit，软件开发工具包) command defaults.
GSTBK_JAVA_APP_DIR=./chain-apps/fisco-bcos-java-sdk
GRADLE_BIN=
GSTBK_PERSONAL_INFO_GRADLE_TASK=personalInfo
GSTBK_SIGNATURE_GRADLE_TASK=signature

# Evidence and logs. Keep generated outputs outside Git or under ignored paths.
GSTBK_RUNTIME_LOG_DIR=./runtime-logs
GSTBK_RUNTIME_STATE_DIR=./runtime-state
